{
  "name": "@pretty-cozy/root",
  "version": "0.0.0",
  "description": "Collection of pretty cozy utilities to make npm workflows easier",
  "author": "Pretty Coffee",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter='./packages/*' run build",
    "publish": "pnpm run build && node ./scripts/publish.js",
    "lint": "eslint",
    "lint:fix": "pnpm run lint --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@pretty-cozy/eslint-config": "workspace:*",
    "@types/node": "^24.12.2",
    "enquirer": "2.4.1",
    "eslint": "9.39.4",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "npm-run-all2": "8.0.4",
    "typescript": "6.0.3"
  }
}

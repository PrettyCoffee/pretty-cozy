{
  "name": "@pretty-cozy/root",
  "version": "0.0.0",
  "description": "Collection of pretty cozy utilities to make npm workflows easier",
  "author": "Pretty Coffee",
  "license": "MIT",
  "workspaces": [
    "packages/eslint-config",
    "packages/release-tools"
  ],
  "scripts": {
    "build": "npm run -ws --if-present build",
    "publish": "npm run build && node ./scripts/publish.js",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "enquirer": "2.4.1",
    "eslint": "9.39.3",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "npm-run-all2": "8.0.4",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.js": [
      "npm run lint:fix"
    ]
  }
}
